# ============================================================
# AuditAX Nexus Hub — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- FIREBASE (Client-side — safe to expose via VITE_) ---
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# --- FIREBASE ADMIN (Server-side only — keep secret) ---
# Option A: Path to your service account JSON file (local dev)
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Option B: Inline JSON (CI/CD / production)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# --- GEMINI AI ---
GEMINI_API_KEY=AIzaSy...

# --- STRIPE ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- KAFKA (Upstash — recommended for serverless) ---
# Get these from https://console.upstash.com/kafka
KAFKA_BROKERS=your-cluster.upstash.io:9092
KAFKA_USERNAME=your-upstash-username
KAFKA_PASSWORD=your-upstash-password
KAFKA_SSL=true
KAFKA_TOPIC_AI_AUDIT=audit-requests

# --- KAFKA (Confluent Cloud — alternative, more powerful) ---
# Get these from https://confluent.cloud
# KAFKA_BROKERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
# KAFKA_USERNAME=your-api-key
# KAFKA_PASSWORD=your-api-secret
# KAFKA_SSL=true
# KAFKA_TOPIC_AI_AUDIT=audit-requests

# --- SERVER ---
NODE_ENV=development
PORT=3000
